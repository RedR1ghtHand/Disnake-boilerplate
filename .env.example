# Discord
BOT_TOKEN=your_bot_token_here
ALLOWED_GUILDS=123456789012345678,987654321098765432
ENVIRONMENT=development
LOG_LEVEL=INFO

# Intents (privileged — enable in Discord Developer Portal too)
MEMBERS_INTENT=false
PRESENCES_INTENT=false
MESSAGE_CONTENT_INTENT=true

# MongoDB — pick one:
# Atlas:       mongodb+srv://user:pass@cluster.mongodb.net/
# Local host:  mongodb://localhost:27017
# Docker local mongo overlay sets MONGODB_URI automatically (see docker-compose.local.yml)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=bot
